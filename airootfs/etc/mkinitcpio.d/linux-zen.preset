# mkinitcpio preset file for the 'linux-zen' package

#ALL_config="/etc/mkinitcpio.conf"
ALL_kver="/boot/vmlinuz-linux-zen"

PRESETS=('live')

live_config="/etc/mkinitcpio.conf.d/archiso.conf"
live_image="/boot/initramfs-linux-zen.img"
live_uki="/efi/EFI/Linux/arch-linux-zen.efi"
live_options="--cmdline /etc/kernel/cmdline-linux-zen"
