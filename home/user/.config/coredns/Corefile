user.home.arpa:53 {
  bind 127.0.0.1 ::1 172.29.0.1

  cache 512

  etcd {
    path /coredns
    endpoint http://127.0.0.1:2379 http://[::1]:2379 https://etcd.user.home.arpa:2379
    tls /home/user/.config/letsencrypt/live/etcd.user.home.arpa/fullchain.pem /home/user/.config/letsencrypt/live/etcd.user.home.arpa/privkey.pem /home/user/.config/letsencrypt/live/etcd.user.home.arpa/chain.pem
  }

  header {
    response set ra
  }

  loadbalance
}

