#!/usr/bin/bash

set -eu

resolve_device_like_initcpio() {
    local spec="$1"
    local dev=""

    case "$spec" in
        UUID=*|LABEL=*|PARTUUID=*|PARTLABEL=*)
            dev="$(blkid -lt "$spec" -o device 2>/dev/null | head -n1 || true)"
            if [[ -z "$dev" ]]; then
                case "$spec" in
                    UUID=*) dev="/dev/disk/by-uuid/${spec#UUID=}" ;;
                    LABEL=*) dev="/dev/disk/by-label/${spec#LABEL=}" ;;
                    PARTUUID=*) dev="/dev/disk/by-partuuid/${spec#PARTUUID=}" ;;
                    PARTLABEL=*) dev="/dev/disk/by-partlabel/${spec#PARTLABEL=}" ;;
                esac
            fi
            ;;
    esac

    [[ -n "${dev}" ]] || dev="${spec}"
    printf '%s\n' "${dev}"
}

_mnt_dev() {
    local dev="$1" mnt="$2" flg="$3" opts="$4" resolved_dev rootdelay

    rootdelay="$(grep -oE '(^| )rootdelay=[^ ]+' /proc/cmdline 2>/dev/null | tail -n1 | cut -d= -f2)"
    [[ -n "${rootdelay}" ]] || rootdelay=30

    while :; do
        resolved_dev="$(resolve_device_like_initcpio "${dev}")"
        if [[ "${resolved_dev}" == /dev/* ]] && [[ -b "${resolved_dev}" || -e "${resolved_dev}" ]]; then
            break
        fi

        sleep 1
        rootdelay=$((rootdelay - 1))
        if (( rootdelay <= 0 )); then
            echo "overlay-initrd: ERROR unable to resolve ${dev}" >&2
            return 1
        fi
    done

    case "${dev}" in
        UUID=*|LABEL=*|PARTUUID=*|PARTLABEL=*) : ;;
        *) dev="${resolved_dev}" ;;
    esac

    mount --mkdir -o "x-initrd.mount,${opts}" "${flg}" "${dev}" "${mnt}"
}

_getarg() {
    local key="$1" default="${2:-}" token
    for token in $(< /proc/cmdline); do
        case "${token}" in
            "${key}"=*) printf '%s\n' "${token#*=}"; return 0 ;;
        esac
    done
    printf '%s\n' "${default}"
}

_hasflag() {
    local flag="$1" token
    for token in $(< /proc/cmdline); do
        [[ "${token}" == "${flag}" ]] && return 0
    done
    return 1
}

_find_live_image_path() {
    local root="$1" live_dir="$2" live_image="$3" preferred candidate

    preferred="${root}${live_dir%/}/${live_image}"
    if [[ -f "${preferred}" ]]; then
        printf '%s\n' "${preferred}"
        return 0
    fi

    candidate="$(find "${root}" -maxdepth 5 -type f -name "${live_image}" 2>/dev/null | head -n1 || true)"
    [[ -n "${candidate}" ]] || return 1
    printf '%s\n' "${candidate}"
}

_mem_available_kib() {
    awk '$1=="MemAvailable:" { print $2; exit }' /proc/meminfo
}

_prepare_squash_source_image() {
    local src_img="$1" copy_mode="$2"
    local img_name img_kib mem_kib reserve_kib src_size dst_size copy_tmpfs_kib

    img_name="${src_img##*/}"

    if _hasflag nocopytoram; then
        copy_mode="n"
    fi
    if _hasflag copytoram; then
        copy_mode="y"
    fi

    if [[ "${copy_mode}" == "auto" ]]; then
        img_kib="$(du -bsk "${src_img}" | cut -f1)"
        mem_kib="$(_mem_available_kib)"
        reserve_kib=$((4 * 1024 * 1024))
        if [[ -n "${mem_kib}" ]] && (( mem_kib > img_kib + reserve_kib )); then
            copy_mode="y"
        else
            copy_mode="n"
        fi
    fi

    if [[ "${copy_mode}" != "y" ]]; then
        printf '%s\n' "${src_img}"
        return 0
    fi

    copy_tmpfs_kib=$((img_kib + 128 * 1024))
    mount --mkdir -t tmpfs -o "x-initrd.mount,size=${copy_tmpfs_kib}k,mode=0755" tmpfs /run/squashfs
    if ! dd if="${src_img}" of="/run/squashfs/${img_name}" bs=8M iflag=fullblock status=none conv=fsync; then
        printf '%s\n' "${src_img}"
        return 0
    fi

    src_size="$(du -b "${src_img}" | cut -f1)"
    dst_size="$(du -b "/run/squashfs/${img_name}" | cut -f1)"
    if [[ -z "${src_size}" || -z "${dst_size}" || "${src_size}" != "${dst_size}" ]]; then
        printf '%s\n' "${src_img}"
        return 0
    fi

    umount /run/live/squashfs >/dev/null 2>&1 || true
    printf '%s\n' "/run/squashfs/${img_name}"
}

_mount_lower_squash() {
    local img="$1" loopdev

    loopdev="$(losetup --find --show --read-only -- "${img}")"
    if ! mount --mkdir -t squashfs -o "x-initrd.mount,ro" "${loopdev}" /run/sysroot; then
        losetup -d "${loopdev}" >/dev/null 2>&1 || true
        return 1
    fi
}

_overlay_fstype_supports_upper() {
    local fstype="$1"
    case "${fstype}" in
        ext2|ext3|ext4|xfs|btrfs|f2fs) return 0 ;;
        *) return 1 ;;
    esac
}

_mount_final_overlay_root() {
    local upper_dir="/run/live/overlay/upper"
    local work_dir="/run/live/overlay/work"

    mkdir -p /sysroot
    mkdir -p "${upper_dir}" "${work_dir}"
    mount -t overlay -o "x-initrd.mount,index=off,lowerdir=/run/sysroot,upperdir=${upper_dir},workdir=${work_dir}" live /sysroot
}

main() {
    local live_dev live_squashfs live_dir live_image live_overlay
    local live_img active_img overlay_fstype

    live_dev="$(_getarg live.dev)"
    live_squashfs="$(_getarg live.squashfs)"
    live_dir="$(_getarg live.dir /squashfs)"
    live_image="$(_getarg live.image airootfs.sfs)"
    live_overlay="$(_getarg live.overlay)"

    [[ -n "${live_dev}" ]] || {
        echo "overlay-initrd: ERROR kernel option live.dev= is required" >&2
        exit 1
    }
    [[ -n "${live_overlay}" ]] || {
        echo "overlay-initrd: ERROR kernel option live.overlay= is required" >&2
        exit 1
    }

    if [[ -n "${live_squashfs}" ]]; then
        _mnt_dev "${live_squashfs}" /run/live/squashfs -r defaults || exit 1
        live_img="$(_find_live_image_path /run/live/squashfs / "${live_image}")" || {
            echo "overlay-initrd: ERROR no root image found in live.squashfs mount" >&2
            exit 1
        }
    else
        _mnt_dev "${live_dev}" /run/live/squashfs -r defaults || exit 1
        live_img="$(_find_live_image_path /run/live/squashfs "${live_dir}" "${live_image}")" || {
            echo "overlay-initrd: ERROR no root image found in /run/live/squashfs" >&2
            exit 1
        }
    fi

    active_img="$(_prepare_squash_source_image "${live_img}" auto)"
    if ! _mount_lower_squash "${active_img}"; then
        if [[ "${active_img}" != "${live_img}" ]] && _mount_lower_squash "${live_img}"; then
            :
        else
            echo "overlay-initrd: ERROR failed to mount squashfs lower at /run/sysroot" >&2
            exit 1
        fi
    fi

    if ! _mnt_dev "${live_overlay}" /run/live/overlay -w "defaults,data=ordered,delalloc,commit=30"; then
        _mnt_dev "${live_overlay}" /run/live/overlay -w defaults || {
            echo "overlay-initrd: ERROR failed to mount live.overlay=${live_overlay}" >&2
            exit 1
        }
    fi

    overlay_fstype="$(awk '$2=="/run/live/overlay" {print $3; exit}' /proc/mounts)"
    _overlay_fstype_supports_upper "${overlay_fstype}" || {
        echo "overlay-initrd: ERROR overlay fs ${overlay_fstype:-unknown} does not support upper/work directories" >&2
        exit 1
    }

    mkdir -p /run/live/overlay/upper /run/live/overlay/work
    rm -rf /run/live/overlay/work/* || true

    if ! _mount_final_overlay_root; then
        rm -rf /run/live/overlay/work /run/live/overlay/upper.incompatible || true
        mv /run/live/overlay/upper /run/live/overlay/upper.incompatible 2>/dev/null || true
        mkdir -p /run/live/overlay/upper /run/live/overlay/work
        _mount_final_overlay_root || {
            echo "overlay-initrd: ERROR failed to mount final root overlay at /sysroot" >&2
            exit 1
        }
    fi
}

main "$@"
