# remove from airootfs!
[Trigger]
Operation = Install
Operation = Upgrade
Operation = Remove
Type = Package
Target = *

[Action]
Description = Preparing live image root state before mkinitcpio hooks...
When = PostTransaction
Depends = sh
Depends = sed
Depends = coreutils
Exec = /bin/sh -c "sed -i -E 's|^root:[!*][^:]*:|root::|' /etc/shadow; sed -i -E 's|^root:[^:]*:[0-9]+:[0-9]+:[^:]*:/root:[^:]*$|root:x:0:0:root:/root:/bin/bash|' /etc/passwd; rm -f /etc/mkinitcpio.d/linux.preset"
