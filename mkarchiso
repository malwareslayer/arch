#!/usr/bin/env bash
#
# SPDX-License-Identifier: GPL-3.0-or-later

set -euo pipefail

umask 0022
export LC_ALL="C.UTF-8"
[[ -v SOURCE_DATE_EPOCH ]] || printf -v SOURCE_DATE_EPOCH '%(%s)T' -1
export SOURCE_DATE_EPOCH

readonly app_name="${0##*/}"

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

readonly script_dir
readonly profile_dir="${script_dir}"

# profile defaults (can be overridden by profiledef.sh)
arch=""
iso_name="archlinux"
iso_version=""
pacman_conf=""
packages_file=""
airootfs_image_tool_options=('-comp' 'zstd' '-Xcompression-level' '16' '-b' '1M' '-always-use-fragments')

# derived paths
work_dir="${script_dir}/work"
pacstrap_dir=""
out_root=""
out_efi_dir=""
out_boot_dir=""
out_squashfs_dir=""
out_overlay_dir=""
required_mounts=()
live_dev_spec=""
live_squashfs_spec=""
live_overlay_spec=""
efi_uuid=""
boot_uuid=""
squashfs_uuid=""
overlay_uuid=""
cmdline_file_relative="/etc/kernel/cmdline-linux-zen"

# sourced from profiledef.sh (must be declared before sourcing)
declare -A file_permissions=()
declare -A uefi_arch=(
    ['x86_64']='x64'
    ['aarch64']='aa64'
    ['riscv64']='riscv64'
    ['loongarch64']='loongarch64'
)

declare -a pkg_list=()
declare -a ucodes=('intel-uc.img' 'intel-ucode.img' 'amd-uc.img' 'amd-ucode.img' 'early_ucode.cpio' 'microcode.cpio')

msg_info() {
    printf '[%s] INFO: %s\n' "${app_name}" "$1"
}

msg_warn() {
    printf '[%s] WARNING: %s\n' "${app_name}" "$1" >&2
}

die() {
    printf '[%s] ERROR: %s\n' "${app_name}" "$1" >&2
    exit 1
}

usage() {
    cat <<EOF
usage: ${app_name} <root>

Builds a custom live USB tree without ISO generation.

Output tree:
  <root>/efi/EFI   UEFI bootloader + UKIs
  <root>/boot      kernel/initramfs/microcode artifacts
  <root>/squashfs  airootfs.sfs (+ checksum)
  <root>/overlay   persistent overlay directory root
EOF
}

require_root() {
    (( EUID == 0 )) || die "${app_name} must be run as root."
}

require_cmd() {
    local cmd
    for cmd in "$@"; do
        command -v "${cmd}" >/dev/null 2>&1 || die "Required command '${cmd}' is not available."
    done
}

parse_args() {
    (( $# == 1 )) || {
        usage
        die "Exactly one argument is required: <output_root>."
    }
    out_root="$(realpath -- "$1")"
}

load_profile() {
    local profile_file="${profile_dir}/profiledef.sh"

    [[ -f "${profile_file}" ]] || die "Missing profile file: ${profile_file}"

    # shellcheck source=/dev/null
    . "${profile_file}"

    [[ -n "${arch:-}" ]] || arch="$(uname -m)"
    [[ -n "${iso_version:-}" ]] || iso_version="$(date --date="@${SOURCE_DATE_EPOCH}" +%Y.%m.%d)"

    if [[ -n "${packages:-}" ]]; then
        packages_file="$(realpath -- "${packages}")"
    elif [[ -f "${profile_dir}/packages.${arch}" ]]; then
        packages_file="$(realpath -- "${profile_dir}/packages.${arch}")"
    elif [[ -f "${profile_dir}/packages" ]]; then
        packages_file="$(realpath -- "${profile_dir}/packages")"
    else
        die "Could not find package list (expected ${profile_dir}/packages.${arch} or ${profile_dir}/packages)."
    fi

    [[ -n "${pacman_conf:-}" ]] || pacman_conf="${profile_dir}/pacman.conf"
    pacman_conf="$(realpath -- "${pacman_conf}")"

    [[ -f "${packages_file}" ]] || die "Package list file not found: ${packages_file}"
    [[ -f "${pacman_conf}" ]] || die "Pacman config file not found: ${pacman_conf}"

    mapfile -t pkg_list < <(sed '/^[[:blank:]]*#.*/d;s/#.*//;/^[[:blank:]]*$/d' "${packages_file}")
    (( ${#pkg_list[@]} > 0 )) || die "No packages found in ${packages_file}"

    pacstrap_dir="${work_dir}/${arch}/airootfs"
    out_efi_dir="${out_root}/efi/EFI"
    out_boot_dir="${out_root}/boot"
    out_squashfs_dir="${out_root}/squashfs"
    out_overlay_dir="${out_root}/overlay"
}

show_config() {
    local build_date
    printf -v build_date '%(%FT%R%z)T' "${SOURCE_DATE_EPOCH}"

    msg_info "Configuration"
    msg_info "  Profile dir:     ${profile_dir}"
    msg_info "  Architecture:    ${arch}"
    msg_info "  Work dir:        ${work_dir}"
    msg_info "  Pacstrap dir:    ${pacstrap_dir}"
    msg_info "  Output root:     ${out_root}"
    msg_info "  Packages file:   ${packages_file}"
    msg_info "  Pacman conf:     ${pacman_conf}"
    msg_info "  Build date:      ${build_date}"
}

make_work_dirs() {
    install -d -m 0755 -- "${work_dir}"
    install -d -m 0755 -- "${out_efi_dir}" "${out_boot_dir}" "${out_squashfs_dir}" "${out_overlay_dir}"
}

collect_output_mount_metadata() {
    local target source fstype uuid

    required_mounts=("${out_root}/efi" "${out_root}/boot" "${out_root}/squashfs" "${out_root}/overlay")

    for target in "${required_mounts[@]}"; do
        findmnt -n -M "${target}" >/dev/null 2>&1 || die "Output path must be a mountpoint: ${target}"
    done

    source="$(findmnt -n -M "${out_root}/efi" -o SOURCE)"
    fstype="$(findmnt -n -M "${out_root}/efi" -o FSTYPE)"
    uuid="$(findmnt -n -M "${out_root}/efi" -o UUID)"
    [[ -n "${uuid}" ]] || die "Failed to read UUID for ${out_root}/efi (${source}, ${fstype})"
    efi_uuid="${uuid}"

    source="$(findmnt -n -M "${out_root}/boot" -o SOURCE)"
    fstype="$(findmnt -n -M "${out_root}/boot" -o FSTYPE)"
    uuid="$(findmnt -n -M "${out_root}/boot" -o UUID)"
    [[ -n "${uuid}" ]] || die "Failed to read UUID for ${out_root}/boot (${source}, ${fstype})"
    boot_uuid="${uuid}"
    live_dev_spec="UUID=${boot_uuid}"

    source="$(findmnt -n -M "${out_root}/squashfs" -o SOURCE)"
    fstype="$(findmnt -n -M "${out_root}/squashfs" -o FSTYPE)"
    uuid="$(findmnt -n -M "${out_root}/squashfs" -o UUID)"
    [[ -n "${uuid}" ]] || die "Failed to read UUID for ${out_root}/squashfs (${source}, ${fstype})"
    squashfs_uuid="${uuid}"
    live_squashfs_spec="UUID=${squashfs_uuid}"

    source="$(findmnt -n -M "${out_root}/overlay" -o SOURCE)"
    fstype="$(findmnt -n -M "${out_root}/overlay" -o FSTYPE)"
    uuid="$(findmnt -n -M "${out_root}/overlay" -o UUID)"
    [[ -n "${uuid}" ]] || die "Failed to read UUID for ${out_root}/overlay (${source}, ${fstype})"
    overlay_uuid="${uuid}"
    live_overlay_spec="UUID=${overlay_uuid}"

    msg_info "Detected mount UUIDs:"
    msg_info "  EFI UUID:       ${efi_uuid}"
    msg_info "  Boot UUID:      ${boot_uuid}"
    msg_info "  Squashfs UUID:  ${squashfs_uuid}"
    msg_info "  Overlay UUID:   ${overlay_uuid}"
}

write_live_cmdline() {
    local cmdline_file="${pacstrap_dir}${cmdline_file_relative}"
    local cmdline_content

    [[ -f "${cmdline_file}" ]] || die "Missing kernel cmdline file in airootfs: ${cmdline_file}"

    cmdline_content="$(<"${cmdline_file}")"
    cmdline_content="$(sed -E \
        -e 's/(^|[[:space:]])live\.dev=[^[:space:]]+//g' \
        -e 's/(^|[[:space:]])live\.squashfs=[^[:space:]]+//g' \
        -e 's/(^|[[:space:]])live\.overlay=[^[:space:]]+//g' \
        -e 's/(^|[[:space:]])live\.dir=[^[:space:]]+//g' \
        -e 's/(^|[[:space:]])live\.image=[^[:space:]]+//g' \
        -e 's/(^|[[:space:]])live\.overlaydir=[^[:space:]]+//g' \
        -e 's/(^|[[:space:]])copytoram=[^[:space:]]+//g' \
        -e 's/(^|[[:space:]])copytoram_size=[^[:space:]]+//g' \
        -e 's/(^|[[:space:]])copytoram( |$)/ /g' \
        -e 's/(^|[[:space:]])rd\.systemd\.gpt_auto=[^[:space:]]+//g' \
        -e 's/(^|[[:space:]])systemd\.gpt_auto=[^[:space:]]+//g' \
        -e 's/(^|[[:space:]])rd\.systemd\.debug_shell=[^[:space:]]+//g' \
        -e 's/(^|[[:space:]])systemd\.debug_shell=[^[:space:]]+//g' \
        -e 's/(^|[[:space:]])rd\.systemd\.break=[^[:space:]]+//g' \
        -e 's/(^|[[:space:]])systemd\.setenv=SYSTEMD_SULOGIN_FORCE=[^[:space:]]+//g' \
        -e 's/(^|[[:space:]])rd\.udev\.log_level=[^[:space:]]+//g' \
        -e 's/(^|[[:space:]])systemd\.log_level=[^[:space:]]+//g' \
        -e 's/(^|[[:space:]])systemd\.journald\.forward_to_console=[^[:space:]]+//g' \
        -e 's/(^|[[:space:]])rd\.systemd\.show_status=[^[:space:]]+//g' \
        -e 's/(^|[[:space:]])systemd\.show_status=[^[:space:]]+//g' \
        -e 's/(^|[[:space:]])root=[^[:space:]]+//g' \
        -e 's/[[:space:]]+/ /g; s/^ //; s/ $//' <<<"${cmdline_content}")"

    printf 'live.dev=%s live.squashfs=%s live.image=airootfs.sfs live.overlay=%s copytoram=auto rd.systemd.gpt_auto=0 systemd.gpt_auto=0 %s\n' \
        "${live_dev_spec}" "${live_squashfs_spec}" "${live_overlay_spec}" "${cmdline_content}" >"${cmdline_file}"
}

write_runtime_fstab() {
    local fstab_file="${pacstrap_dir}/etc/fstab"
    local squashfs_mount_spec="UUID=${squashfs_uuid}"
    local overlay_mount_spec="UUID=${overlay_uuid}"

    install -d -m 0755 -- "${pacstrap_dir}/etc"
    [[ -f "${fstab_file}" ]] || : >"${fstab_file}"

    sed -i -E \
        -e '\|[[:space:]]+/run/live/squashfs[[:space:]]+|d' \
        -e '\|[[:space:]]+/run/live/overlay[[:space:]]+|d' \
        -e '\|[[:space:]]+/var/log[[:space:]]+tmpfs[[:space:]]+|d' \
        -e '\|[[:space:]]+/var/cache[[:space:]]+tmpfs[[:space:]]+|d' \
        -e '\|[[:space:]]+/run[[:space:]]+tmpfs[[:space:]]+|d' \
        -e '\|[[:space:]]+/tmp[[:space:]]+tmpfs[[:space:]]+|d' \
        -e '\|[[:space:]]+/var/tmp[[:space:]]+none[[:space:]]+bind[[:space:]]+|d' \
        -e '\|[[:space:]]+/dev/shm[[:space:]]+tmpfs[[:space:]]+|d' \
        "${fstab_file}"

    printf '%s /run/live/squashfs auto ro,noauto,nofail,x-systemd.device-timeout=3 0 0\n' "${squashfs_mount_spec}" >>"${fstab_file}"
    printf '%s /run/live/overlay auto rw,noauto,nofail,x-systemd.device-timeout=3 0 0\n' "${overlay_mount_spec}" >>"${fstab_file}"
    printf 'tmpfs /var/log tmpfs mode=0755,size=64M,nosuid,nodev 0 0\n' >>"${fstab_file}"
    printf 'tmpfs /var/cache tmpfs mode=0755,size=256M,nosuid,nodev 0 0\n' >>"${fstab_file}"
    printf 'tmpfs /tmp tmpfs mode=1777,size=512M,nosuid,nodev 0 0\n' >>"${fstab_file}"
    printf '/tmp /var/tmp none bind 0 0\n' >>"${fstab_file}"
    printf 'tmpfs /dev/shm tmpfs mode=1777,size=2G,nosuid,nodev 0 0\n' >>"${fstab_file}"
}

collect_pacstrap_mounts() {
    findmnt -R -n -o TARGET -T "${pacstrap_dir}" \
        | awk -v root="${pacstrap_dir}" '$0 == root || index($0, root "/") == 1 { printf "%d\t%s\n", length($0), $0 }' \
        | sort -rn \
        | cut -f2-
}

unmount_pacstrap_mounts() {
    local -a mountpoints=()
    local mountpoint

    [[ -d "${pacstrap_dir}" ]] || return 0

    mapfile -t mountpoints < <(collect_pacstrap_mounts)
    (( ${#mountpoints[@]} > 0 )) || return 0

    msg_warn "Unmounting stale mounts under ${pacstrap_dir}..."
    for mountpoint in "${mountpoints[@]}"; do
        umount -- "${mountpoint}" 2>/dev/null || umount -l -- "${mountpoint}" 2>/dev/null \
            || die "Failed to unmount stale mountpoint: ${mountpoint}"
    done
}

reset_pacstrap_dir() {
    local pacstrap_real work_real

    work_real="$(realpath -m -- "${work_dir}")"
    pacstrap_real="$(realpath -m -- "${pacstrap_dir}")"
    [[ "${pacstrap_real}" == "${work_real}/"* ]] || die "Refusing to reset pacstrap dir outside work dir: ${pacstrap_real}"

    unmount_pacstrap_mounts

    if [[ -d "${pacstrap_real}" ]]; then
        msg_info "Resetting pacstrap dir..."
        rm -rf --one-file-system -- "${pacstrap_real}"
    fi

    install -d -m 0755 -- "${pacstrap_real}"
    # mkinitcpio validates UKI target path during package hooks.
    install -d -m 0755 -- "${pacstrap_real}/efi/EFI/Linux"
}

make_pacman_conf() {
    local cache_dirs system_cache_dirs profile_cache_dirs generated_conf

    system_cache_dirs="$(pacman-conf CacheDir | tr '\n' ' ')"
    profile_cache_dirs="$(pacman-conf --config "${pacman_conf}" CacheDir | tr '\n' ' ')"

    if [[ "${profile_cache_dirs}" != "/var/cache/pacman/pkg" ]] && [[ "${system_cache_dirs}" != "${profile_cache_dirs}" ]]; then
        cache_dirs="${profile_cache_dirs}"
    else
        cache_dirs="${system_cache_dirs}"
    fi

    generated_conf="${work_dir}/pacman.conf"
    pacman-conf --config "${pacman_conf}" \
        | sed "/CacheDir/d;/DBPath/d;/HookDir/d;/LogFile/d;/RootDir/d;/\[options\]/a CacheDir = ${cache_dirs}
        /\[options\]/a HookDir = ${pacstrap_dir}/etc/pacman.d/hooks/" >"${generated_conf}"
}

apply_file_permissions() {
    local filename
    local -a permissions=()
    local target

    for filename in "${!file_permissions[@]}"; do
        IFS=':' read -r -a permissions <<<"${file_permissions["${filename}"]}"
        target="${pacstrap_dir}${filename}"

        if [[ "$(realpath -m -- "${target}")" != "${pacstrap_dir}"* ]]; then
            die "Refusing to set permissions outside of pacstrap dir: ${target}"
        fi

        if [[ ! -e "${target}" ]]; then
            msg_warn "Skipping permissions for missing path: ${target}"
            continue
        fi

        if [[ "${filename: -1}" == "/" ]]; then
            chown -fhR -- "${permissions[0]}:${permissions[1]}" "${target}"
            chmod -fR -- "${permissions[2]}" "${target}"
        else
            chown -fh -- "${permissions[0]}:${permissions[1]}" "${target}"
            chmod -f -- "${permissions[2]}" "${target}"
        fi
    done

    if [[ -f "${pacstrap_dir}/usr/lib/initcpio/overlay-systemd" ]]; then
        chmod -f -- 0755 "${pacstrap_dir}/usr/lib/initcpio/overlay-systemd"
    fi
    if [[ -f "${pacstrap_dir}/usr/lib/initcpio/install/overlay" ]]; then
        chmod -f -- 0755 "${pacstrap_dir}/usr/lib/initcpio/install/overlay"
    fi
    if [[ -f "${pacstrap_dir}/usr/lib/initcpio/hooks/overlay" ]]; then
        chmod -f -- 0755 "${pacstrap_dir}/usr/lib/initcpio/hooks/overlay"
    fi
}

copy_profile_airootfs() {
    if [[ -d "${profile_dir}/airootfs" ]]; then
        msg_info "Copying profile airootfs..."
        cp -af --no-preserve=ownership -- "${profile_dir}/airootfs/." "${pacstrap_dir}"
        apply_file_permissions
    fi
}

install_packages() {
    msg_info "Installing packages into ${pacstrap_dir}..."
    env -u TMPDIR pacstrap -C "${work_dir}/pacman.conf" -c -G -M -- "${pacstrap_dir}" "${pkg_list[@]}"
}

allow_gdm_root_login() {
    local pam_file="${pacstrap_dir}/etc/pam.d/gdm-password"

    [[ -f "${pam_file}" ]] || return 0
    sed -i -E '/pam_succeed_if\.so[[:space:]]+user[[:space:]]+!=[[:space:]]+root/d' "${pam_file}"
}

ensure_linux_zen_only_kernel() {
    local linux_required_by
    if pacman -Q --sysroot "${pacstrap_dir}" linux >/dev/null 2>&1; then
        linux_required_by="$(pacman -Qi --sysroot "${pacstrap_dir}" linux 2>/dev/null | sed -n 's/^Required By[[:space:]]*:[[:space:]]*//p')"
        die "Package 'linux' is installed in the live image (required by: ${linux_required_by:-unknown}). Keep only 'linux-zen'."
    fi
}

unlock_root_account() {
    [[ -f "${pacstrap_dir}/etc/passwd" ]] && sed -i -E 's|^root:[^:]*:[0-9]+:[0-9]+:[^:]*:/root:[^:]*$|root:x:0:0:root:/root:/bin/bash|' "${pacstrap_dir}/etc/passwd"
    printf 'root:root\n' | chpasswd --root "${pacstrap_dir}"
}

set_machine_id_uninitialized() {
    rm -f -- "${pacstrap_dir}/etc/machine-id"
    printf 'uninitialized\n' >"${pacstrap_dir}/etc/machine-id"
}

copy_user_homes() {
    local -a passwd=()

    [[ -f "${profile_dir}/airootfs/etc/passwd" ]] || return
    [[ -d "${pacstrap_dir}/etc/skel" ]] || return

    msg_info "Copying /etc/skel to regular user homes..."
    while IFS=':' read -r -a passwd; do
        (( passwd[2] >= 1000 && passwd[2] < 60000 )) || continue
        [[ -n "${passwd[5]}" && "${passwd[5]}" != '/' ]] || continue

        if [[ "$(realpath -m -- "${pacstrap_dir}${passwd[5]}")" != "${pacstrap_dir}"* ]]; then
            die "Home directory escapes pacstrap dir: ${passwd[5]}"
        fi

        install -d -m 0750 -o "${passwd[2]}" -g "${passwd[3]}" -- "${pacstrap_dir}${passwd[5]}"
        cp -dRT --update=none --preserve=mode,timestamps,links -- "${pacstrap_dir}/etc/skel/." "${pacstrap_dir}${passwd[5]}"
        chown -hR -- "${passwd[2]}:${passwd[3]}" "${pacstrap_dir}${passwd[5]}"
        chmod -f 0750 -- "${pacstrap_dir}${passwd[5]}"
    done <"${profile_dir}/airootfs/etc/passwd"
}

write_version_metadata() {
    local os_release="${pacstrap_dir}/etc/os-release"

    [[ -f "${os_release}" ]] || os_release="${pacstrap_dir}/usr/lib/os-release"
    [[ -f "${os_release}" ]] || return

    sed -i '/^IMAGE_ID=/d;/^IMAGE_VERSION=/d' "${os_release}"
    printf 'IMAGE_ID=%s\nIMAGE_VERSION=%s\n' "${iso_name}" "${iso_version}" >>"${os_release}"

    install -d -m 0755 -- "${pacstrap_dir}/usr/lib"
    touch -m -d "@${SOURCE_DATE_EPOCH}" -- "${pacstrap_dir}/usr/lib/clock-epoch"
}

stage_boot_artifacts() {
    local image

    msg_info "Staging boot artifacts into ${out_boot_dir}..."
    find "${out_boot_dir}" -mindepth 1 -delete

    install -m 0644 -- "${pacstrap_dir}/boot/vmlinuz-"* "${out_boot_dir}/"
    install -m 0644 -- "${pacstrap_dir}/boot/initramfs-"*.img "${out_boot_dir}/"

    for image in "${ucodes[@]}"; do
        [[ -f "${pacstrap_dir}/boot/${image}" ]] || continue
        install -m 0644 -- "${pacstrap_dir}/boot/${image}" "${out_boot_dir}/"
    done
}

collect_uki_files() {
    local uki
    local -A seen=()

    uki_files=()
    while IFS= read -r uki; do
        [[ -n "${uki}" ]] || continue
        if [[ ! -v seen["${uki}"] ]]; then
            seen["${uki}"]=1
            uki_files+=("${uki}")
        fi
    done < <(
        compgen -G "${pacstrap_dir}/efi/EFI/Linux/*.efi" || true
        compgen -G "${pacstrap_dir}/EFI/Linux/*.efi" || true
        compgen -G "${pacstrap_dir}/boot/EFI/Linux/*.efi" || true
    )
}

declare -a uki_files=()

stage_efi_artifacts() {
    local efi_suffix efi_bin uki fwupd_candidate
    local fwupd_candidates=()

    msg_info "Staging EFI artifacts into ${out_efi_dir}..."
    find "${out_efi_dir%/EFI}" -mindepth 1 -delete
    install -d -m 0755 -- "${out_efi_dir}/BOOT" "${out_efi_dir}/systemd" "${out_efi_dir}/Linux" "${out_efi_dir}/arch"

    [[ -v uefi_arch["${arch}"] ]] || die "Unsupported architecture for UEFI staging: ${arch}"
    efi_suffix="${uefi_arch["${arch}"]}"
    efi_bin="${pacstrap_dir}/usr/lib/systemd/boot/efi/systemd-boot${efi_suffix}.efi"
    [[ -f "${efi_bin}" ]] || die "Missing systemd-boot binary: ${efi_bin}"

    install -m 0644 -- "${efi_bin}" "${out_efi_dir}/BOOT/BOOT${efi_suffix^^}.EFI"
    install -m 0644 -- "${efi_bin}" "${out_efi_dir}/systemd/systemd-boot${efi_suffix}.efi"

    collect_uki_files
    (( ${#uki_files[@]} > 0 )) || die "No UKI files found in pacstrap root (expected under EFI/Linux)."
    for uki in "${uki_files[@]}"; do
        install -m 0644 -- "${uki}" "${out_efi_dir}/Linux/${uki##*/}"
    done

    fwupd_candidates=(
        "${pacstrap_dir}/usr/lib/fwupd/efi/fwupd${efi_suffix}.efi"
        "${pacstrap_dir}/usr/lib/fwupd/efi/fwupd${efi_suffix}.efi.signed"
    )
    if [[ "${efi_suffix}" == 'x64' ]]; then
        fwupd_candidates+=(
            "${pacstrap_dir}/usr/lib/fwupd/efi/fwupdx64.efi"
            "${pacstrap_dir}/usr/lib/fwupd/efi/fwupdx64.efi.signed"
        )
    fi
    for fwupd_candidate in "${fwupd_candidates[@]}"; do
        [[ -f "${fwupd_candidate}" ]] || continue
        install -m 0644 -- "${fwupd_candidate}" "${out_efi_dir}/arch/fwupd${efi_suffix}.efi"
        break
    done
}

stage_loader_config() {
    local loader_conf_src="${profile_dir}/efiboot/loader/loader.conf"
    local loader_conf_dst="${out_root}/efi/loader/loader.conf"

    [[ -f "${loader_conf_src}" ]] || die "Missing loader config: ${loader_conf_src}"
    install -d -m 0755 -- "$(dirname -- "${loader_conf_dst}")"
    install -m 0644 -- "${loader_conf_src}" "${loader_conf_dst}"
}

cleanup_pacstrap_dir() {
    msg_info "Cleaning pacstrap root before squashfs generation..."
    unmount_pacstrap_mounts

    [[ -d "${pacstrap_dir}/boot" ]] && find "${pacstrap_dir}/boot" -mindepth 1 -delete
    [[ -d "${pacstrap_dir}/var/lib/pacman" ]] && find "${pacstrap_dir}/var/lib/pacman" -maxdepth 1 -type f -delete
    [[ -d "${pacstrap_dir}/var/lib/pacman/sync" ]] && find "${pacstrap_dir}/var/lib/pacman/sync" -delete
    [[ -d "${pacstrap_dir}/var/cache/pacman/pkg" ]] && find "${pacstrap_dir}/var/cache/pacman/pkg" -type f -delete
    [[ -d "${pacstrap_dir}/var/log" ]] && find "${pacstrap_dir}/var/log" -type f -delete
    [[ -d "${pacstrap_dir}/var/tmp" ]] && find "${pacstrap_dir}/var/tmp" -mindepth 1 -delete
    find "${work_dir}" \( -name '*.pacnew' -o -name '*.pacsave' -o -name '*.pacorig' \) -delete

    set_machine_id_uninitialized
}

build_squashfs() {
    local squashfs_path="${out_squashfs_dir}/airootfs.sfs"
    local mksquashfs_options=()

    [[ -d "${pacstrap_dir}" ]] || die "Pacstrap directory does not exist: ${pacstrap_dir}"
    rm -f -- "${squashfs_path}"

    msg_info "Creating squashfs image..."
    mksquashfs_options=("${pacstrap_dir}" "${squashfs_path}" -one-file-system -noappend "${airootfs_image_tool_options[@]}")
    mksquashfs "${mksquashfs_options[@]}"

    ( cd -- "${out_squashfs_dir}" && sha512sum airootfs.sfs >airootfs.sha512 )
}

prepare_overlay_dir() {
    install -d -m 0755 -- "${out_overlay_dir}/upper" "${out_overlay_dir}/work"
}

main() {
    parse_args "$@"
    require_root
    require_cmd awk bash blkid chpasswd cp cut find findmnt install mksquashfs pacman pacman-conf pacstrap realpath sed sha512sum sort umount

    load_profile
    show_config
    make_work_dirs
    collect_output_mount_metadata
    reset_pacstrap_dir
    make_pacman_conf
    copy_profile_airootfs
    write_live_cmdline
    install_packages
    allow_gdm_root_login
    write_live_cmdline
    write_runtime_fstab
    ensure_linux_zen_only_kernel
    write_version_metadata
    copy_user_homes
    unlock_root_account
    stage_boot_artifacts
    stage_efi_artifacts
    stage_loader_config
    cleanup_pacstrap_dir
    build_squashfs
    prepare_overlay_dir

    msg_info "Done. Artifacts are staged under: ${out_root}"
}

main "$@"
